# Copy to .env.local for development; set both in Vercel project settings for production.
# Password visitors enter to unlock protected case studies:
CASE_STUDY_PASSWORD=
# Random string used to sign the unlock cookie (e.g. `openssl rand -hex 32`):
AUTH_SECRET=
# Canonical production URL — used for metadataBase, sitemap.xml, robots.txt,
# and OG/Twitter tags. Falls back to the current Vercel deployment if unset.
NEXT_PUBLIC_SITE_URL=
